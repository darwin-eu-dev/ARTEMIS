#!/bin/sh
# .githooks/commit-msg
# Validates commit message against Conventional Commits format.
# Activate with: git config core.hooksPath .githooks

commit_msg_file="$1"
commit_msg=$(cat "$commit_msg_file")

# Skip merge commits
case "$commit_msg" in
  Merge*)   exit 0 ;;
  Revert*)  exit 0 ;;
esac

# Skip rebase / fixup autogenerated lines
case "$commit_msg" in
  fixup!*)   exit 0 ;;
  squash!*)  exit 0 ;;
esac

# Validate against Conventional Commits pattern
# type(scope): description  — scope is optional
pattern='^(feat|fix|chore|docs|style|refactor|test|ci|perf)(\(.+\))?!?: .+'

if ! printf '%s' "$commit_msg" | grep -qE "$pattern"; then
  printf '\n✘ Invalid commit message.\n'
  printf '  Expected: type(scope): description\n'
  printf '  Got:      %s\n' "$commit_msg"
  printf '  Valid types: feat fix chore docs style refactor test ci perf\n'
  printf '  See: vignette("testing-strategy") — Conventional Commits section\n\n'
  exit 1
fi

exit 0
